#!/bin/bash
# Decline the visitor who's knocking. Optional reason as argument.
# Usage: decline [reason]
REASON="${*:-Not right now.}"
curl -s -X POST http://localhost:8420/decline \
  -H "Content-Type: application/json" \
  -d "{\"reason\": \"$REASON\"}" | python3 -m json.tool 2>/dev/null || echo "No one at the door (or presence server not running)."
